{ 
  "ReverseProxy": {
    "Routes": {
      "gallery-route": {
        "ClusterId": "gallery-cluster",
        "Match": {
          "Path": "/gallery/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPrefix": "/api"
          },
          {
            "RequestHeadersCopy": "true"
          }
        ]
      },
      "identity-route": {
        "ClusterId": "identity-cluster",
        "Match": {
          "Path": "/identity/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPrefix": "/api"
          }
        ]
      }
    },
    "Clusters": {
      "gallery-cluster": {
        "Destinations": {
          "gallery-destination": {
            "Address": "http://localhost:5001/"
          }
        }
      },
      "identity-cluster": {
        "Destinations": {
          "identity-destination": {
            "Address": "http://localhost:5002/"
          }
        }
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}