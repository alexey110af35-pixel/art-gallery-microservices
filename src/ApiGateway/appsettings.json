{
  "ReverseProxy": {
    "Routes": {
      "gallery-route": {
        "ClusterId": "gallery-cluster",
        "Match": {
          "Path": "/gallery/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPrefix": "/api"
          }
        ]
      }
    },
    "Clusters": {
      "gallery-cluster": {
        "Destinations": {
          "gallery-destination": {
            "Address": "https://localhost:5001/"
          }
        }
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}